# In-tree build backend (referenced by [build-system] backend-path); must be
# present in the sdist so a wheel can be built from it.
include _build_meta.py
include _translations.py

# Translation catalogs: .po are the source (tracked in git); .mo are generated
# at build time by the backend and are not tracked in git. Ship both so the
# sdist is self-contained.
recursive-include djangoql/locale *.po *.mo
