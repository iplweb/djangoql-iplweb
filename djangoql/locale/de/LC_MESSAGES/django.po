#, python-format
msgid "Line %(line)s, col %(col)s"
msgstr "Zeile %(line)s, Spalte %(col)s"

#, python-format
msgid "Line %s"
msgstr "Zeile %s"

#, python-format
msgid "Illegal character %s"
msgstr "Ungültiges Zeichen %s"

msgid "Unexpected end of input"
msgstr "Unerwartetes Ende der Eingabe"

#, python-format
msgid "Syntax error at %s"
msgstr "Syntaxfehler bei %s"

#, python-format
msgid "Field %s is not nullable, can't compare it to None"
msgstr "Feld %s darf nicht null sein und kann nicht mit None verglichen werden"

#, python-brace-format
msgid ""
"Field \"{field}\" has \"nullable {field_type}\" type. It can be compared to "
"{possible_values} or None, but not to {value}"
msgstr ""
"Feld \"{field}\" hat den Typ \"nullable {field_type}\". Es kann mit "
"{possible_values} oder None verglichen werden, aber nicht mit {value}"

#, python-brace-format
msgid ""
"Field \"{field}\" has \"{field_type}\" type. It can be compared to "
"{possible_values}, but not to {value}"
msgstr ""
"Feld \"{field}\" hat den Typ \"{field_type}\". Es kann mit "
"{possible_values} verglichen werden, aber nicht mit {value}"

msgid "integer numbers"
msgstr "Ganzzahlen"

msgid "floating point numbers"
msgstr "Fließkommazahlen"

msgid "strings"
msgstr "Zeichenketten"

msgid "True or False"
msgstr "True oder False"

msgid "dates in \"YYYY-MM-DD\" format"
msgstr "Datumsangaben im Format \"YYYY-MM-DD\""

#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to dates in \"YYYY-MM-DD\" format, but not "
"to {value}"
msgstr ""
"Feld \"{field}\" kann mit Datumsangaben im Format \"YYYY-MM-DD\" verglichen "
"werden, aber nicht mit {value}"

msgid "timestamps in \"YYYY-MM-DD HH:MM\" format"
msgstr "Zeitstempel im Format \"YYYY-MM-DD HH:MM\""

#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to timestamps in \"YYYY-MM-DD HH:MM\" "
"format, but not to {value}"
msgstr ""
"Feld \"{field}\" kann mit Zeitstempeln im Format \"YYYY-MM-DD HH:MM\" "
"verglichen werden, aber nicht mit {value}"

msgid "Schema must be initialized with a subclass of Django model"
msgstr ""
"Das Schema muss mit einer Unterklasse eines Django-Modells initialisiert "
"werden"

msgid "Either include or exclude can be specified, but not both"
msgstr "Es kann entweder include oder exclude angegeben werden, aber nicht beides"

#, python-brace-format
msgid "{model} can't be used with {schema_class} because it's excluded from it"
msgstr ""
"{model} kann nicht mit {schema_class} verwendet werden, da es davon "
"ausgeschlossen ist"

#, python-brace-format
msgid "Unknown field: {field}. Possible choices are: {choices}"
msgstr "Unbekanntes Feld: {field}. Mögliche Werte: {choices}"

#, python-brace-format
msgid ""
"Related model {model} can be compared to None only, but not to {value_type}"
msgstr ""
"Das verwandte Modell {model} kann nur mit None verglichen werden, aber "
"nicht mit {value_type}"

msgid "DjangoQL syntax help"
msgstr "DjangoQL-Syntaxhilfe"

msgid "page must be an integer starting from 1"
msgstr "page muss eine Ganzzahl ab 1 sein"

msgid "DjangoQL schema is undefined"
msgstr "DjangoQL-Schema ist nicht definiert"

msgid "\"field\" parameter is required"
msgstr "Parameter \"field\" ist erforderlich"

#, python-format
msgid "Unknown model: %s"
msgstr "Unbekanntes Modell: %s"

#, python-format
msgid "Unknown field: %s"
msgstr "Unbekanntes Feld: %s"

#, python-brace-format
msgid "{model}.{field} doesn't support suggestions"
msgstr "{model}.{field} unterstützt keine Vorschläge"
