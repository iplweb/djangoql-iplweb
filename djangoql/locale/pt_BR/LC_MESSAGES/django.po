#, python-format
msgid "Line %(line)s, col %(col)s"
msgstr "Linha %(line)s, col. %(col)s"

#, python-format
msgid "Line %s"
msgstr "Linha %s"

#, python-format
msgid "Illegal character %s"
msgstr "Caractere inválido %s"

msgid "Unexpected end of input"
msgstr "Fim de entrada inesperado"

#, python-format
msgid "Syntax error at %s"
msgstr "Erro de sintaxe em %s"

#, python-format
msgid "Field %s is not nullable, can't compare it to None"
msgstr "O campo %s não aceita null, não pode ser comparado com None"

#, python-brace-format
msgid ""
"Field \"{field}\" has \"nullable {field_type}\" type. It can be compared to "
"{possible_values} or None, but not to {value}"
msgstr ""
"O campo \"{field}\" é do tipo \"nullable {field_type}\". Pode ser comparado "
"com {possible_values} ou com None, mas não com {value}"

#, python-brace-format
msgid ""
"Field \"{field}\" has \"{field_type}\" type. It can be compared to "
"{possible_values}, but not to {value}"
msgstr ""
"O campo \"{field}\" é do tipo \"{field_type}\". Pode ser comparado com "
"{possible_values}, mas não com {value}"

msgid "integer numbers"
msgstr "números inteiros"

msgid "floating point numbers"
msgstr "números de ponto flutuante"

msgid "strings"
msgstr "strings"

msgid "True or False"
msgstr "True ou False"

msgid "dates in \"YYYY-MM-DD\" format"
msgstr "datas no formato \"YYYY-MM-DD\""

#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to dates in \"YYYY-MM-DD\" format, but not "
"to {value}"
msgstr ""
"O campo \"{field}\" pode ser comparado com datas no formato "
"\"YYYY-MM-DD\", mas não com {value}"

msgid "timestamps in \"YYYY-MM-DD HH:MM\" format"
msgstr "timestamps no formato \"YYYY-MM-DD HH:MM\""

#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to timestamps in \"YYYY-MM-DD HH:MM\" "
"format, but not to {value}"
msgstr ""
"O campo \"{field}\" pode ser comparado com timestamps no formato "
"\"YYYY-MM-DD HH:MM\", mas não com {value}"

msgid "Schema must be initialized with a subclass of Django model"
msgstr "O schema precisa ser inicializado com uma subclasse de modelo Django"

msgid "Either include or exclude can be specified, but not both"
msgstr "É possível especificar include ou exclude, mas não ambos"

#, python-brace-format
msgid "{model} can't be used with {schema_class} because it's excluded from it"
msgstr "{model} não pode ser usado com {schema_class} porque está excluído dele"

#, python-brace-format
msgid "Unknown field: {field}. Possible choices are: {choices}"
msgstr "Campo desconhecido: {field}. Opções disponíveis: {choices}"

#, python-brace-format
msgid ""
"Related model {model} can be compared to None only, but not to {value_type}"
msgstr ""
"O modelo relacionado {model} só pode ser comparado com None, mas não com "
"{value_type}"

msgid "DjangoQL syntax help"
msgstr "Ajuda da sintaxe DjangoQL"

msgid "page must be an integer starting from 1"
msgstr "page deve ser um inteiro a partir de 1"

msgid "DjangoQL schema is undefined"
msgstr "O schema DjangoQL não está definido"

msgid "\"field\" parameter is required"
msgstr "O parâmetro \"field\" é obrigatório"

#, python-format
msgid "Unknown model: %s"
msgstr "Modelo desconhecido: %s"

#, python-format
msgid "Unknown field: %s"
msgstr "Campo desconhecido: %s"

#, python-brace-format
msgid "{model}.{field} doesn't support suggestions"
msgstr "{model}.{field} não suporta sugestões"
