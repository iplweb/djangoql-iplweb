#: exceptions.py:15
#, python-format
msgid "Line %(line)s, col %(col)s"
msgstr "Linha %(line)s, col. %(col)s"

#: exceptions.py:20
#, python-format
msgid "Line %s"
msgstr "Linha %s"

#: extras.py:69
#| msgid "timestamps in \"YYYY-MM-DD HH:MM\" format"
msgid "times in \"HH:MM[:SS]\" format"
msgstr "horários no formato \"HH:MM[:SS]\""

#: extras.py:99
#, python-brace-format
#| msgid ""
#| "Field \"{field}\" can be compared to timestamps in \"YYYY-MM-DD HH:MM\" "
#| "format, but not to {value}"
msgid ""
"Field \"{field}\" can be compared to times in \"HH:MM[:SS]\" format, but not "
"to {value}"
msgstr ""
"O campo \"{field}\" pode ser comparado com horários no formato "
"\"HH:MM[:SS]\", mas não com {value}"

#: extras.py:224
#| msgid "integer numbers"
msgid "numbers"
msgstr "números"

#: extras.py:419
#, python-brace-format
msgid ""
"Relation aggregates are hidden from suggestions: use <relation>__count and "
"<relation>.<numeric_field>__{{sum,avg,min,max}} — e.g. {examples}."
msgstr ""
"Os agregados de relações ficam ocultos das sugestões: use <relation>__count "
"e <relation>.<numeric_field>__{{sum,avg,min,max}} — ex.: {examples}."

#: extras.py:486
#, python-brace-format
msgid ""
"Date/time parts are hidden too: use <field>__{{year,month,day,hour,...}} — "
"e.g. {example}."
msgstr ""
"As partes de data/hora também ficam ocultas: use "
"<field>__{{year,month,day,hour,...}} — ex.: {example}."

#: extras.py:702
#, python-brace-format
#| msgid ""
#| "Field \"{field}\" can be compared to dates in \"YYYY-MM-DD\" format, but "
#| "not to {value}"
msgid "Field \"{field}\" expects a string value, but got {value}"
msgstr ""
"O campo \"{field}\" espera uma string, mas recebeu {value}"

#: lexer.py:169
#, python-format
msgid "Illegal character %s"
msgstr "Caractere inválido %s"

#: parser.py:210
msgid "Unexpected end of input"
msgstr "Fim de entrada inesperado"

#: parser.py:216
#, python-format
msgid "Syntax error at %s"
msgstr "Erro de sintaxe em %s"

#: schema.py:169
#, python-format
msgid "Field %s is not nullable, can't compare it to None"
msgstr "O campo %s não aceita null, não pode ser comparado com None"

#: schema.py:175
#, python-brace-format
msgid ""
"Field \"{field}\" has \"nullable {field_type}\" type. It can be compared to "
"{possible_values} or None, but not to {value}"
msgstr ""
"O campo \"{field}\" é do tipo \"nullable {field_type}\". Pode ser comparado "
"com {possible_values} ou com None, mas não com {value}"

#: schema.py:181
#, python-brace-format
msgid ""
"Field \"{field}\" has \"{field_type}\" type. It can be compared to "
"{possible_values}, but not to {value}"
msgstr ""
"O campo \"{field}\" é do tipo \"{field_type}\". Pode ser comparado com "
"{possible_values}, mas não com {value}"

#: schema.py:198
msgid "integer numbers"
msgstr "números inteiros"

#: schema.py:210
msgid "floating point numbers"
msgstr "números de ponto flutuante"

#: schema.py:216
msgid "strings"
msgstr "strings"

#: schema.py:236
msgid "True or False"
msgstr "True ou False"

#: schema.py:242
msgid "dates in \"YYYY-MM-DD\" format"
msgstr "datas no formato \"YYYY-MM-DD\""

#: schema.py:251
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to dates in \"YYYY-MM-DD\" format, but not "
"to {value}"
msgstr ""
"O campo \"{field}\" pode ser comparado com datas no formato \"YYYY-MM-DD\", "
"mas não com {value}"

#: schema.py:273
msgid "timestamps in \"YYYY-MM-DD HH:MM\" format"
msgstr "timestamps no formato \"YYYY-MM-DD HH:MM\""

#: schema.py:282
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to timestamps in \"YYYY-MM-DD HH:MM\" "
"format, but not to {value}"
msgstr ""
"O campo \"{field}\" pode ser comparado com timestamps no formato \"YYYY-MM-"
"DD HH:MM\", mas não com {value}"

#: schema.py:356
msgid "Schema must be initialized with a subclass of Django model"
msgstr "O schema precisa ser inicializado com uma subclasse de modelo Django"

#: schema.py:360
msgid "Either include or exclude can be specified, but not both"
msgstr "É possível especificar include ou exclude, mas não ambos"

#: schema.py:365
#, python-brace-format
msgid "{model} can't be used with {schema_class} because it's excluded from it"
msgstr ""
"{model} não pode ser usado com {schema_class} porque está excluído dele"

#: schema.py:591
#, python-brace-format
#| msgid "Unknown field: {field}. Possible choices are: {choices}"
msgid "Unknown field: {field}. Did you mean: {suggestions}?"
msgstr "Campo desconhecido: {field}. Você quis dizer: {suggestions}?"

#: schema.py:602
#, python-brace-format
msgid "Unknown field: {field}. Possible choices are: {choices}"
msgstr "Campo desconhecido: {field}. Opções disponíveis: {choices}"

#: schema.py:649
#, python-brace-format
msgid ""
"Related model {model} can be compared to None only, but not to {value_type}"
msgstr ""
"O modelo relacionado {model} só pode ser comparado com None, mas não com "
"{value_type}"

#: templates/djangoql/empty_breakdown.html:3
msgid "No results. Where the query runs out of data:"
msgstr "Nenhum resultado. Onde a consulta fica sem dados:"

#: templates/djangoql/empty_breakdown.html:7
msgid ""
"Breakdown truncated: the query is too large; only the top-level conditions "
"were evaluated."
msgstr ""
"Detalhamento truncado: a consulta é muito grande; apenas as condições de "
"nível superior foram avaliadas."

#: templates/djangoql/empty_breakdown_node.html:6
msgid "no data from here on"
msgstr "sem dados a partir daqui"

#: templates/djangoql/empty_breakdown_node.html:8
msgid "this branch is empty"
msgstr "este ramo está vazio"

#: templates/djangoql/error_message.html:5
msgid "DjangoQL syntax help"
msgstr "Ajuda da sintaxe DjangoQL"

#: views.py:22
msgid "page must be an integer starting from 1"
msgstr "page deve ser um inteiro a partir de 1"

#: views.py:54
msgid "DjangoQL schema is undefined"
msgstr "O schema DjangoQL não está definido"

#: views.py:56
msgid "\"field\" parameter is required"
msgstr "O parâmetro \"field\" é obrigatório"

#: views.py:69
#, python-format
msgid "Unknown model: %s"
msgstr "Modelo desconhecido: %s"

#: views.py:72
#, python-format
msgid "Unknown field: %s"
msgstr "Campo desconhecido: %s"

#: views.py:78
#, python-brace-format
msgid "{model}.{field} doesn't support suggestions"
msgstr "{model}.{field} não suporta sugestões"
