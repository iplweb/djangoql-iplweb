#, python-format
msgid "Line %(line)s, col %(col)s"
msgstr "Línea %(line)s, col. %(col)s"

#, python-format
msgid "Line %s"
msgstr "Línea %s"

#, python-format
msgid "Illegal character %s"
msgstr "Carácter no permitido %s"

msgid "Unexpected end of input"
msgstr "Fin de entrada inesperado"

#, python-format
msgid "Syntax error at %s"
msgstr "Error de sintaxis en %s"

#, python-format
msgid "Field %s is not nullable, can't compare it to None"
msgstr "El campo %s no admite null y no puede compararse con None"

#, python-brace-format
msgid ""
"Field \"{field}\" has \"nullable {field_type}\" type. It can be compared to "
"{possible_values} or None, but not to {value}"
msgstr ""
"El campo \"{field}\" es de tipo \"nullable {field_type}\". Puede compararse "
"con {possible_values} o con None, pero no con {value}"

#, python-brace-format
msgid ""
"Field \"{field}\" has \"{field_type}\" type. It can be compared to "
"{possible_values}, but not to {value}"
msgstr ""
"El campo \"{field}\" es de tipo \"{field_type}\". Puede compararse con "
"{possible_values}, pero no con {value}"

msgid "integer numbers"
msgstr "números enteros"

msgid "floating point numbers"
msgstr "números de coma flotante"

msgid "strings"
msgstr "cadenas de texto"

msgid "True or False"
msgstr "True o False"

msgid "dates in \"YYYY-MM-DD\" format"
msgstr "fechas en formato \"YYYY-MM-DD\""

#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to dates in \"YYYY-MM-DD\" format, but not "
"to {value}"
msgstr ""
"El campo \"{field}\" puede compararse con fechas en formato "
"\"YYYY-MM-DD\", pero no con {value}"

msgid "timestamps in \"YYYY-MM-DD HH:MM\" format"
msgstr "marcas de tiempo en formato \"YYYY-MM-DD HH:MM\""

#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to timestamps in \"YYYY-MM-DD HH:MM\" "
"format, but not to {value}"
msgstr ""
"El campo \"{field}\" puede compararse con marcas de tiempo en formato "
"\"YYYY-MM-DD HH:MM\", pero no con {value}"

msgid "Schema must be initialized with a subclass of Django model"
msgstr "El esquema debe inicializarse con una subclase de un modelo Django"

msgid "Either include or exclude can be specified, but not both"
msgstr "Se puede especificar include o exclude, pero no ambos"

#, python-brace-format
msgid "{model} can't be used with {schema_class} because it's excluded from it"
msgstr "{model} no puede usarse con {schema_class} porque está excluido de él"

#, python-brace-format
msgid "Unknown field: {field}. Possible choices are: {choices}"
msgstr "Campo desconocido: {field}. Opciones disponibles: {choices}"

#, python-brace-format
msgid ""
"Related model {model} can be compared to None only, but not to {value_type}"
msgstr ""
"El modelo relacionado {model} sólo puede compararse con None, pero no con "
"{value_type}"

msgid "DjangoQL syntax help"
msgstr "Ayuda de sintaxis de DjangoQL"

msgid "page must be an integer starting from 1"
msgstr "page debe ser un entero a partir de 1"

msgid "DjangoQL schema is undefined"
msgstr "El esquema de DjangoQL no está definido"

msgid "\"field\" parameter is required"
msgstr "El parámetro \"field\" es obligatorio"

#, python-format
msgid "Unknown model: %s"
msgstr "Modelo desconocido: %s"

#, python-format
msgid "Unknown field: %s"
msgstr "Campo desconocido: %s"

#, python-brace-format
msgid "{model}.{field} doesn't support suggestions"
msgstr "{model}.{field} no admite sugerencias"
