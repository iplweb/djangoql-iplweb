#: exceptions.py:15
#, python-format
msgid "Line %(line)s, col %(col)s"
msgstr "Рядок %(line)s, стовпець %(col)s"

#: exceptions.py:20
#, python-format
msgid "Line %s"
msgstr "Рядок %s"

#: extras.py:69
msgid "times in \"HH:MM[:SS]\" format"
msgstr "часом у форматі \"HH:MM[:SS]\""

#: extras.py:99
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to times in \"HH:MM[:SS]\" format, but not "
"to {value}"
msgstr ""
"Поле \"{field}\" можна порівняти з часом у форматі \"HH:MM[:SS]\", але не з "
"{value}"

#: extras.py:224
msgid "numbers"
msgstr "числами"

#: extras.py:419
#, python-brace-format
msgid ""
"Relation aggregates are hidden from suggestions: use <relation>__count and "
"<relation>.<numeric_field>__{{sum,avg,min,max}} — e.g. {examples}."
msgstr ""
"Агрегати за зв’язками приховані з підказок: використовуйте <relation>__count "
"та <relation>.<numeric_field>__{{sum,avg,min,max}} — наприклад, {examples}."

#: extras.py:486
#, python-brace-format
msgid ""
"Date/time parts are hidden too: use <field>__{{year,month,day,hour,...}} — "
"e.g. {example}."
msgstr ""
"Частини дати/часу також приховані: використовуйте "
"<field>__{{year,month,day,hour,...}} — наприклад, {example}."

#: extras.py:702
#, python-brace-format
msgid "Field \"{field}\" expects a string value, but got {value}"
msgstr "Поле \"{field}\" очікує рядкове значення, але отримано {value}"

#: lexer.py:169
#, python-format
msgid "Illegal character %s"
msgstr "Недопустимий символ %s"

#: parser.py:210
msgid "Unexpected end of input"
msgstr "Неочікуваний кінець введення"

#: parser.py:216
#, python-format
msgid "Syntax error at %s"
msgstr "Синтаксична помилка біля %s"

#: schema.py:169
#, python-format
msgid "Field %s is not nullable, can't compare it to None"
msgstr "Поле %s не може бути null, його не можна порівняти з None"

#: schema.py:175
#, python-brace-format
msgid ""
"Field \"{field}\" has \"nullable {field_type}\" type. It can be compared to "
"{possible_values} or None, but not to {value}"
msgstr ""
"Поле \"{field}\" має тип \"nullable {field_type}\". Його можна порівняти з "
"{possible_values} або з None, але не з {value}"

#: schema.py:181
#, python-brace-format
msgid ""
"Field \"{field}\" has \"{field_type}\" type. It can be compared to "
"{possible_values}, but not to {value}"
msgstr ""
"Поле \"{field}\" має тип \"{field_type}\". Його можна порівняти з "
"{possible_values}, але не з {value}"

#: schema.py:198
msgid "integer numbers"
msgstr "цілими числами"

#: schema.py:210
msgid "floating point numbers"
msgstr "числами з плаваючою комою"

#: schema.py:216
msgid "strings"
msgstr "рядками"

#: schema.py:236
msgid "True or False"
msgstr "True або False"

#: schema.py:242
msgid "dates in \"YYYY-MM-DD\" format"
msgstr "датами у форматі \"YYYY-MM-DD\""

#: schema.py:251
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to dates in \"YYYY-MM-DD\" format, but not "
"to {value}"
msgstr ""
"Поле \"{field}\" можна порівняти з датами у форматі \"YYYY-MM-DD\", але не з "
"{value}"

#: schema.py:273
msgid "timestamps in \"YYYY-MM-DD HH:MM\" format"
msgstr "мітками часу у форматі \"YYYY-MM-DD HH:MM\""

#: schema.py:282
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to timestamps in \"YYYY-MM-DD HH:MM\" "
"format, but not to {value}"
msgstr ""
"Поле \"{field}\" можна порівняти з мітками часу у форматі \"YYYY-MM-DD "
"HH:MM\", але не з {value}"

#: schema.py:356
msgid "Schema must be initialized with a subclass of Django model"
msgstr "Схему треба ініціалізувати підкласом моделі Django"

#: schema.py:360
msgid "Either include or exclude can be specified, but not both"
msgstr "Можна вказати або include, або exclude, але не обидва одночасно"

#: schema.py:365
#, python-brace-format
msgid "{model} can't be used with {schema_class} because it's excluded from it"
msgstr "{model} не може використовуватись з {schema_class}, бо її виключено"

#: schema.py:591
#, python-brace-format
msgid "Unknown field: {field}. Did you mean: {suggestions}?"
msgstr "Невідоме поле: {field}. Можливо, ви мали на увазі: {suggestions}?"

#: schema.py:602
#, python-brace-format
msgid "Unknown field: {field}. Possible choices are: {choices}"
msgstr "Невідоме поле: {field}. Можливі варіанти: {choices}"

#: schema.py:649
#, python-brace-format
msgid ""
"Related model {model} can be compared to None only, but not to {value_type}"
msgstr ""
"Пов'язану модель {model} можна порівнювати лише з None, але не з {value_type}"

#: templates/djangoql/empty_breakdown.html:3
msgid "No results. Where the query runs out of data:"
msgstr "Немає результатів. Де у запиту закінчуються дані:"

#: templates/djangoql/empty_breakdown.html:7
msgid ""
"Breakdown truncated: the query is too large; only the top-level conditions "
"were evaluated."
msgstr ""
"Розбір скорочено: запит завеликий; обчислено лише умови верхнього рівня."

#: templates/djangoql/empty_breakdown_node.html:6
msgid "no data from here on"
msgstr "далі даних немає"

#: templates/djangoql/empty_breakdown_node.html:8
msgid "this branch is empty"
msgstr "ця гілка порожня"

#: templates/djangoql/error_message.html:5
msgid "DjangoQL syntax help"
msgstr "Довідка з синтаксису DjangoQL"

#: views.py:22
msgid "page must be an integer starting from 1"
msgstr "page має бути цілим числом, що починається з 1"

#: views.py:54
msgid "DjangoQL schema is undefined"
msgstr "Схема DjangoQL не визначена"

#: views.py:56
msgid "\"field\" parameter is required"
msgstr "Параметр \"field\" є обов'язковим"

#: views.py:69
#, python-format
msgid "Unknown model: %s"
msgstr "Невідома модель: %s"

#: views.py:72
#, python-format
msgid "Unknown field: %s"
msgstr "Невідоме поле: %s"

#: views.py:78
#, python-brace-format
msgid "{model}.{field} doesn't support suggestions"
msgstr "{model}.{field} не підтримує підказки"
