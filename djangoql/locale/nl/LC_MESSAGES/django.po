#: exceptions.py:15
#, python-format
msgid "Line %(line)s, col %(col)s"
msgstr "Regel %(line)s, kolom %(col)s"

#: exceptions.py:20
#, python-format
msgid "Line %s"
msgstr "Regel %s"

#: extras.py:69
msgid "times in \"HH:MM[:SS]\" format"
msgstr "tijden in het formaat \"HH:MM[:SS]\""

#: extras.py:99
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to times in \"HH:MM[:SS]\" format, but not "
"to {value}"
msgstr ""
"Veld \"{field}\" kan vergeleken worden met tijden in het formaat "
"\"HH:MM[:SS]\", maar niet met {value}"

#: extras.py:224
msgid "numbers"
msgstr "getallen"

#: extras.py:419
#, python-brace-format
msgid ""
"Relation aggregates are hidden from suggestions: use <relation>__count and "
"<relation>.<numeric_field>__{{sum,avg,min,max}} — e.g. {examples}."
msgstr ""
"Relatie-aggregaten worden verborgen in de suggesties: gebruik "
"<relation>__count en <relation>.<numeric_field>__{{sum,avg,min,max}} — "
"bijv. {examples}."

#: extras.py:486
#, python-brace-format
msgid ""
"Date/time parts are hidden too: use <field>__{{year,month,day,hour,...}} — "
"e.g. {example}."
msgstr ""
"Datum-/tijdonderdelen worden ook verborgen: gebruik "
"<field>__{{year,month,day,hour,...}} — bijv. {example}."

#: extras.py:702
#, python-brace-format
msgid "Field \"{field}\" expects a string value, but got {value}"
msgstr ""
"Veld \"{field}\" verwacht een tekenreeks, maar kreeg {value}"

#: lexer.py:169
#, python-format
msgid "Illegal character %s"
msgstr "Ongeldig teken %s"

#: parser.py:210
msgid "Unexpected end of input"
msgstr "Onverwacht einde van invoer"

#: parser.py:216
#, python-format
msgid "Syntax error at %s"
msgstr "Syntaxfout bij %s"

#: schema.py:169
#, python-format
msgid "Field %s is not nullable, can't compare it to None"
msgstr "Veld %s mag niet null zijn en kan niet met None worden vergeleken"

#: schema.py:175
#, python-brace-format
msgid ""
"Field \"{field}\" has \"nullable {field_type}\" type. It can be compared to "
"{possible_values} or None, but not to {value}"
msgstr ""
"Veld \"{field}\" is van het type \"nullable {field_type}\". Het kan "
"vergeleken worden met {possible_values} of met None, maar niet met {value}"

#: schema.py:181
#, python-brace-format
msgid ""
"Field \"{field}\" has \"{field_type}\" type. It can be compared to "
"{possible_values}, but not to {value}"
msgstr ""
"Veld \"{field}\" is van het type \"{field_type}\". Het kan vergeleken worden "
"met {possible_values}, maar niet met {value}"

#: schema.py:198
msgid "integer numbers"
msgstr "gehele getallen"

#: schema.py:210
msgid "floating point numbers"
msgstr "getallen met drijvende komma"

#: schema.py:216
msgid "strings"
msgstr "tekenreeksen"

#: schema.py:236
msgid "True or False"
msgstr "True of False"

#: schema.py:242
msgid "dates in \"YYYY-MM-DD\" format"
msgstr "datums in het formaat \"YYYY-MM-DD\""

#: schema.py:251
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to dates in \"YYYY-MM-DD\" format, but not "
"to {value}"
msgstr ""
"Veld \"{field}\" kan vergeleken worden met datums in het formaat \"YYYY-MM-"
"DD\", maar niet met {value}"

#: schema.py:273
msgid "timestamps in \"YYYY-MM-DD HH:MM\" format"
msgstr "tijdstempels in het formaat \"YYYY-MM-DD HH:MM\""

#: schema.py:282
#, python-brace-format
msgid ""
"Field \"{field}\" can be compared to timestamps in \"YYYY-MM-DD HH:MM\" "
"format, but not to {value}"
msgstr ""
"Veld \"{field}\" kan vergeleken worden met tijdstempels in het formaat "
"\"YYYY-MM-DD HH:MM\", maar niet met {value}"

#: schema.py:356
msgid "Schema must be initialized with a subclass of Django model"
msgstr ""
"Het schema moet geïnitialiseerd worden met een subklasse van een Django-model"

#: schema.py:360
msgid "Either include or exclude can be specified, but not both"
msgstr "Geef ofwel include ofwel exclude op, maar niet beide"

#: schema.py:365
#, python-brace-format
msgid "{model} can't be used with {schema_class} because it's excluded from it"
msgstr ""
"{model} kan niet met {schema_class} worden gebruikt omdat het uitgesloten is"

#: schema.py:591
#, python-brace-format
msgid "Unknown field: {field}. Did you mean: {suggestions}?"
msgstr "Onbekend veld: {field}. Bedoelde u: {suggestions}?"

#: schema.py:602
#, python-brace-format
msgid "Unknown field: {field}. Possible choices are: {choices}"
msgstr "Onbekend veld: {field}. Mogelijke keuzes: {choices}"

#: schema.py:649
#, python-brace-format
msgid ""
"Related model {model} can be compared to None only, but not to {value_type}"
msgstr ""
"Gerelateerd model {model} kan alleen met None vergeleken worden, maar niet "
"met {value_type}"

#: templates/djangoql/empty_breakdown.html:3
msgid "No results. Where the query runs out of data:"
msgstr "Geen resultaten. Waar de query zonder gegevens komt te zitten:"

#: templates/djangoql/empty_breakdown.html:7
msgid ""
"Breakdown truncated: the query is too large; only the top-level conditions "
"were evaluated."
msgstr ""
"Uitsplitsing afgekapt: de query is te groot; alleen de voorwaarden op het "
"hoogste niveau zijn geëvalueerd."

#: templates/djangoql/empty_breakdown_node.html:6
msgid "no data from here on"
msgstr "vanaf hier geen gegevens meer"

#: templates/djangoql/empty_breakdown_node.html:8
msgid "this branch is empty"
msgstr "deze tak is leeg"

#: templates/djangoql/error_message.html:5
msgid "DjangoQL syntax help"
msgstr "DjangoQL syntaxhulp"

#: views.py:22
msgid "page must be an integer starting from 1"
msgstr "page moet een geheel getal vanaf 1 zijn"

#: views.py:54
msgid "DjangoQL schema is undefined"
msgstr "DjangoQL-schema is niet gedefinieerd"

#: views.py:56
msgid "\"field\" parameter is required"
msgstr "Parameter \"field\" is verplicht"

#: views.py:69
#, python-format
msgid "Unknown model: %s"
msgstr "Onbekend model: %s"

#: views.py:72
#, python-format
msgid "Unknown field: %s"
msgstr "Onbekend veld: %s"

#: views.py:78
#, python-brace-format
msgid "{model}.{field} doesn't support suggestions"
msgstr "{model}.{field} ondersteunt geen suggesties"
